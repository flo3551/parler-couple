---
import { site } from "../../site.config.ts";

const { monetization } = site;

interface NavLink {
  href: string;
  label: Record<string, string>;
}

const labels: Record<string, Record<string, string>> = {
  home:    { fr: "Accueil", en: "Home",  de: "Start",    es: "Inicio" },
  blog:    { fr: "Blog",    en: "Blog",  de: "Blog",     es: "Blog" },
  shop:    { fr: "Boutique",en: "Shop",  de: "Shop",     es: "Tienda" },
  contact: { fr: "Contact", en: "Contact",de: "Kontakt", es: "Contacto" },
  pdf:     { fr: "Guide PDF",en: "PDF Guide",de: "PDF Guide",es: "Guía PDF" },
  lead:    { fr: "Devis",   en: "Quote", de: "Angebot",  es: "Presupuesto" },
};

const l = site.lang;

const baseLinks: NavLink[] = [
  { href: "/", label: labels.home },
  { href: "/blog", label: labels.blog },
];

if (monetization.drop) {
  baseLinks.push({ href: "/shop", label: labels.shop });
}
if (monetization.pdf) {
  baseLinks.push({ href: "/pdf", label: labels.pdf });
}
if (monetization.leadGen) {
  baseLinks.push({ href: "/contact", label: labels.lead });
}

const ctaLabel: Record<string, string> = {
  fr: "Commencer",
  en: "Get Started",
  de: "Starten",
  es: "Empezar",
};
---

<header class="site-header" role="banner">
  <div class="header-inner">
    <!-- Logo / Site name -->
    <a href="/" class="logo" aria-label={site.name}>
      <span class="logo-text">{site.name}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-desktop" aria-label="Navigation principale">
      <ul role="list">
        {baseLinks.map((link) => (
          <li>
            <a href={link.href}>{link.label[l]}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA Button (shown when pdf or leadGen active) -->
    {(monetization.pdf || monetization.leadGen) && (
      <a
        href={monetization.pdf ? "/pdf" : "/contact"}
        class="cta-button"
        aria-label={ctaLabel[l]}
      >
        {ctaLabel[l]}
      </a>
    )}

    <!-- Mobile menu toggle -->
    <button
      class="menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menu"
      type="button"
    >
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <nav id="mobile-menu" class="nav-mobile" aria-label="Navigation mobile" hidden>
    <ul role="list">
      {baseLinks.map((link) => (
        <li>
          <a href={link.href}>{link.label[l]}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255 255 255 / 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgb(0 0 0 / 0.08);
  }
  .header-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1rem;
    height: 4rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .logo { text-decoration: none; }
  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
  }
  .nav-desktop { margin-left: auto; }
  .nav-desktop ul {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-desktop a {
    color: #374151;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.15s;
  }
  .nav-desktop a:hover { color: var(--color-primary); }
  .cta-button {
    padding: 0.5rem 1.25rem;
    background: var(--color-primary);
    color: #fff;
    border-radius: 0.375rem;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .cta-button:hover { opacity: 0.88; }
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    margin-left: auto;
  }
  .bar {
    display: block;
    width: 22px;
    height: 2px;
    background: #374151;
    border-radius: 2px;
  }
  .nav-mobile {
    border-top: 1px solid #e5e7eb;
    padding: 0.75rem 1rem;
  }
  .nav-mobile ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .nav-mobile a {
    display: block;
    padding: 0.5rem 0;
    color: #374151;
    text-decoration: none;
    font-weight: 500;
  }
  @media (max-width: 768px) {
    .nav-desktop { display: none; }
    .menu-toggle { display: flex; }
  }
</style>

<script>
  const toggle = document.querySelector(".menu-toggle") as HTMLButtonElement;
  const menu = document.getElementById("mobile-menu") as HTMLElement;
  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    menu.hidden = open;
  });
</script>
