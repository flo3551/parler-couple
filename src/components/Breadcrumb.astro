---
import { site } from "../../site.config.ts";

interface Crumb {
  label: string;
  href: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;

const homeLabel: Record<string, string> = {
  fr: "Accueil",
  en: "Home",
  de: "Start",
  es: "Inicio",
};

const allCrumbs: Crumb[] = [
  { label: homeLabel[site.lang] ?? "Home", href: "/" },
  ...crumbs,
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: allCrumbs.map((crumb, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: crumb.label,
    item: new URL(crumb.href, site.domain || "https://parler-couple.vercel.app").href,
  })),
};
---

<nav aria-label="Breadcrumb" class="py-3 text-sm text-gray-500">
  <ol class="flex flex-wrap items-center gap-1" role="list">
    {allCrumbs.map((crumb, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && (
          <span aria-hidden="true" class="text-gray-300">/</span>
        )}
        {i < allCrumbs.length - 1 ? (
          <a
            href={crumb.href}
            class="hover:text-gray-800 transition-colors duration-150"
          >
            {crumb.label}
          </a>
        ) : (
          <span aria-current="page" class="text-gray-800 font-medium">
            {crumb.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
