---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const filtered = sorted.filter(p => p.data.tags?.some(t => ["crise", "rupture", "reconstruction", "séparation", "confiance"].includes(t)));
const displayPosts = filtered.length > 0 ? filtered.slice(0, 6) : sorted.slice(0, 6);
---

<BaseLayout
  title="Traverser une Crise de Couple — Ressources"
  description="Votre couple traverse une période difficile ? Ressources, guides et méthodes pour surmonter une crise de couple et reconstruire votre relation."
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <header class="mb-10">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">Traverser une Crise de Couple</h1>
      <p class="text-gray-600 text-lg">Ressources et méthodes concrètes pour surmonter les crises et reconstruire une relation solide.</p>
    </header>

    <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {displayPosts.map(post => (
        <li>
          <ArticleCard
            title={post.data.title}
            slug={post.slug}
            pubDate={post.data.pubDate}
            metaDescription={post.data.metaDescription}
            kw_primary={post.data.kw_primary}
            tags={post.data.tags}
            image={post.data.image}
          />
        </li>
      ))}
    </ul>

    <div class="mt-12 text-center">
      <a href="/blog" class="inline-block px-6 py-3 bg-[var(--color-primary)] text-white font-semibold rounded-xl hover:opacity-90 transition-opacity">
        Voir tous les articles →
      </a>
    </div>
  </div>
</BaseLayout>
