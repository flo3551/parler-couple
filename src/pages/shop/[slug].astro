---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { site } from "../../../site.config.ts";

export async function getStaticPaths() {
  if (!site.monetization.drop) return [];
  const products = await getCollection("products");
  return products.map((p) => ({ params: { slug: p.data.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const p = product.data;
const l = site.lang;

const labels: Record<string, Record<string, string>> = {
  shopLabel: { fr: "Boutique", en: "Shop", de: "Shop", es: "Tienda" },
  buy: { fr: "Acheter maintenant", en: "Buy now", de: "Jetzt kaufen", es: "Comprar ahora" },
  outOfStock: { fr: "Rupture de stock", en: "Out of stock", de: "Nicht verfügbar", es: "Sin stock" },
  benefits: { fr: "Ce que vous obtenez", en: "What you get", de: "Was Sie erhalten", es: "Lo que obtienes" },
  forWho: { fr: "Pour qui ?", en: "Who is it for?", de: "Für wen?", es: "¿Para quién?" },
  reviews: { fr: "Avis clients", en: "Customer reviews", de: "Kundenbewertungen", es: "Reseñas" },
  related: { fr: "Aller plus loin", en: "Learn more", de: "Mehr erfahren", es: "Saber más" },
};

const priceFormatted = new Intl.NumberFormat(l, { style: "currency", currency: "EUR" }).format(p.price);

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: p.name,
  description: p.description,
  image: p.images[0] ?? "",
  keywords: p.seo_kw.join(", "),
  offers: {
    "@type": "Offer",
    url: new URL(`/shop/${p.slug}`, site.domain || "https://parler-couple.vercel.app").href,
    price: p.price.toFixed(2),
    priceCurrency: "EUR",
    availability: p.in_stock
      ? "https://schema.org/InStock"
      : "https://schema.org/OutOfStock",
  },
};

const reviews = [
  { author: "Sophie M.", rating: 5, text: "J'ai offert ce kit à mon mari pour notre anniversaire. On l'a testé le soir même — ça a lancé des conversations qu'on n'avait pas eues depuis des mois." },
  { author: "Marc et Julie", rating: 5, text: "On utilise les cartes tous les dimanches matin avec le café. Simple mais vraiment efficace pour se retrouver." },
  { author: "Amélie, 31 ans", rating: 4, text: "Livraison un peu longue (10 jours) mais la qualité est là. Les questions sont bien dosées entre légèreté et profondeur." },
];
---

<BaseLayout
  title={p.name}
  description={p.description}
  canonical={`/shop/${p.slug}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} slot="head" />

  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumb
      crumbs={[
        { label: labels.shopLabel[l], href: "/shop" },
        { label: p.name, href: `/shop/${p.slug}` },
      ]}
    />

    <div class="mt-6 grid lg:grid-cols-2 gap-10">
      <!-- Product image -->
      <div class="space-y-3">
        {p.images.length > 0 ? (
          <img
            src={p.images[0]}
            alt={p.name}
            class="w-full rounded-xl object-cover aspect-square"
            loading="eager"
          />
        ) : (
          <div class="w-full rounded-xl bg-gray-100 aspect-square flex items-center justify-center">
            <span class="text-gray-400 text-sm">No image</span>
          </div>
        )}
        {p.images.length > 1 && (
          <div class="grid grid-cols-4 gap-2">
            {p.images.slice(1, 5).map((img) => (
              <img src={img} alt={p.name} loading="lazy" class="rounded-lg object-cover aspect-square w-full" />
            ))}
          </div>
        )}
      </div>

      <!-- Product info -->
      <div class="flex flex-col gap-5">
        <!-- Hook tagline -->
        {p.copy_hook && (
          <p class="text-lg italic font-medium text-[var(--color-accent)] leading-snug">{p.copy_hook}</p>
        )}

        <!-- Title + price -->
        <div>
          <h1 class="text-3xl font-bold text-gray-900 mb-3">{p.name}</h1>
          <p class="text-2xl font-bold text-[var(--color-primary)]">{priceFormatted}</p>
        </div>

        <!-- Benefits list -->
        {p.features.length > 0 && (
          <div>
            <h2 class="text-base font-semibold text-gray-800 mb-3">{labels.benefits[l]}</h2>
            <ul class="space-y-2">
              {p.features.map((feat) => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <svg class="w-4 h-4 mt-0.5 text-[var(--color-primary)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  {feat}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Pour qui ? -->
        <div>
          <h2 class="text-base font-semibold text-gray-800 mb-3">{labels.forWho[l]}</h2>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <span class="text-[var(--color-accent)] shrink-0 mt-0.5">&#x2022;</span>
              {l === "fr" ? "Les couples qui veulent ralentir et se retrouver vraiment" : "Couples who want to slow down and reconnect"}
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <span class="text-[var(--color-accent)] shrink-0 mt-0.5">&#x2022;</span>
              {l === "fr" ? "Ceux qui cherchent un cadeau simple mais qui dit quelque chose" : "Those looking for a meaningful yet simple gift"}
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <span class="text-[var(--color-accent)] shrink-0 mt-0.5">&#x2022;</span>
              {l === "fr" ? "Les duos qui ont envie d'aller plus loin que les échanges du quotidien" : "Duos who want to go beyond everyday small talk"}
            </li>
          </ul>
        </div>

        <!-- CTA -->
        <div class="mt-auto space-y-3">
          {p.in_stock ? (
            <button
              id="buy-btn"
              class="block w-full text-center py-3.5 px-6 bg-[var(--color-primary)] text-white font-semibold rounded-xl hover:opacity-90 transition-opacity cursor-pointer"
            >
              {labels.buy[l]}
            </button>
          ) : (
            <span class="block w-full text-center py-3.5 px-6 bg-gray-200 text-gray-500 font-semibold rounded-xl cursor-not-allowed">
              {labels.outOfStock[l]}
            </span>
          )}
        </div>

        <!-- Trust signals -->
        <div class="flex flex-wrap gap-4 text-xs text-gray-500 border-t border-gray-100 pt-4">
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8 5-8-5m0 0v10a2 2 0 002 2h12a2 2 0 002-2V7"/>
            </svg>
            Livraison Europe 7-10j
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            Retours acceptés 30j
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Avis vérifiés
          </span>
        </div>
      </div>
    </div>

    <!-- Reviews section -->
    <section class="mt-14">
      <h2 class="text-xl font-bold text-gray-900 mb-6">{labels.reviews[l]}</h2>
      <ul class="space-y-4">
        {reviews.map((review) => (
          <li class="p-5 rounded-xl border border-gray-100 bg-gray-50">
            <div class="flex items-center gap-2 mb-2">
              <span class="font-medium text-gray-800 text-sm">{review.author}</span>
              <span class="text-[var(--color-accent)] text-sm" aria-label={`${review.rating}/5`}>
                {"★".repeat(review.rating)}{"☆".repeat(5 - review.rating)}
              </span>
            </div>
            <p class="text-sm text-gray-600">{review.text}</p>
          </li>
        ))}
      </ul>
    </section>

    <aside class="mt-10 p-6 rounded-xl bg-gray-50 border border-gray-100">
      <h2 class="text-base font-semibold text-gray-800 mb-3">{labels.related[l]}</h2>
      <ul class="space-y-1.5">
        <li>
          <a href="/blog" class="text-sm text-[var(--color-primary)] hover:underline">
            → {site.lang === "fr" ? "Lire nos articles" : site.lang === "de" ? "Unsere Artikel" : site.lang === "es" ? "Nuestros artículos" : "Read our articles"}
          </a>
        </li>
        {site.monetization.pdf && (
          <li>
            <a href="/download" class="text-sm text-[var(--color-primary)] hover:underline">
              → {site.lang === "fr" ? "Guide PDF gratuit" : site.lang === "de" ? "Kostenloses PDF" : site.lang === "es" ? "Guía PDF gratis" : "Free PDF guide"}
            </a>
          </li>
        )}
      </ul>
    </aside>
  </div>

  <!-- Upsell modal -->
  <div id="upsell-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <!-- Overlay -->
    <div id="upsell-overlay" class="absolute inset-0 bg-black/60"></div>

    <!-- Modal card -->
    <div class="relative z-10 bg-white rounded-2xl shadow-2xl max-w-md w-full p-8">
      <!-- Close button -->
      <button
        id="upsell-close"
        class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors"
        aria-label="Fermer"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-4">Avant de finaliser votre commande...</p>

      <h3 class="text-lg font-bold text-gray-900 mb-1">{p.name}</h3>
      <p class="text-base font-semibold text-[var(--color-primary)] mb-6">{priceFormatted}</p>

      <div class="bg-[var(--color-primary)]/5 border border-[var(--color-primary)]/20 rounded-xl p-5 mb-6">
        <p class="text-sm font-semibold text-gray-800 mb-1">
          + Ajoutez le Guide CNV Couples à <span class="text-[var(--color-accent)]">-50%</span>
          <span class="ml-1 text-[var(--color-primary)] font-bold">11€</span>
          <span class="text-gray-400 line-through text-xs ml-1">22€</span>
        </p>
        <p class="text-sm text-gray-600 italic mt-1">"Les 12 scripts qui transforment vos disputes en dialogues"</p>
      </div>

      <div class="flex flex-col gap-3">
        <a
          href="https://buy.stripe.com/aFacN5dyZcK17HF18RcZa02"
          target="_blank"
          rel="noopener noreferrer"
          class="block w-full text-center py-3.5 px-6 bg-[var(--color-primary)] text-white font-semibold rounded-xl hover:opacity-90 transition-opacity"
        >
          Oui, j'ajoute le guide
        </a>
        <a
          href={p.supplier_url}
          target="_blank"
          rel="noopener noreferrer nofollow"
          class="block w-full text-center py-3 px-6 text-gray-500 text-sm hover:text-gray-700 transition-colors"
        >
          Non merci, juste le produit
        </a>
      </div>
    </div>
  </div>

  <script>
    const buyBtn = document.getElementById('buy-btn');
    const modal = document.getElementById('upsell-modal');
    const closeBtn = document.getElementById('upsell-close');
    const overlay = document.getElementById('upsell-overlay');

    if (buyBtn && modal) {
      buyBtn.addEventListener('click', () => modal.classList.remove('hidden'));
    }
    if (closeBtn && modal) {
      closeBtn.addEventListener('click', () => modal.classList.add('hidden'));
    }
    if (overlay && modal) {
      overlay.addEventListener('click', () => modal.classList.add('hidden'));
    }
  </script>
</BaseLayout>
