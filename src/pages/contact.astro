---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../../site.config.ts";
---

<BaseLayout title="Contact - Parler en Couple" description="Contactez-nous pour toute question sur la communication en couple.">
  <div class="max-w-xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold text-gray-900 mb-3">Contact</h1>
    <p class="text-gray-600 mb-10">Une question, une remarque ou une demande particulière ? Écrivez-nous, nous vous répondons dans les meilleurs délais.</p>

    <form
      action="https://formspree.io/f/placeholder"
      method="POST"
      class="flex flex-col gap-6"
    >
      <div class="flex flex-col gap-1.5">
        <label for="name" class="text-sm font-medium text-gray-700">Nom</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          autocomplete="name"
          class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent transition"
          placeholder="Votre nom"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="email" class="text-sm font-medium text-gray-700">Adresse e-mail</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent transition"
          placeholder="votre@email.fr"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="message" class="text-sm font-medium text-gray-700">Message</label>
        <textarea
          id="message"
          name="message"
          required
          rows="6"
          class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent transition resize-y"
          placeholder="Votre message…"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full px-6 py-3 bg-[var(--color-primary)] text-white font-semibold rounded-xl hover:opacity-90 transition-opacity"
      >
        Envoyer le message
      </button>
    </form>

    <p class="mt-10 text-sm text-gray-500 text-center">
      Vous pouvez aussi nous écrire directement à{" "}
      <a
        href="mailto:contact@parler-couple.fr"
        class="text-[var(--color-primary)] hover:underline font-medium"
      >
        contact@parler-couple.fr
      </a>
    </p>
  </div>
</BaseLayout>
