---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const filtered = sorted.filter(p => p.data.tags?.some(t => ["cnv", "communication", "methode", "écoute", "expression"].includes(t)));
const displayPosts = filtered.length > 0 ? filtered.slice(0, 6) : sorted.slice(0, 6);
---

<BaseLayout
  title="Communication Non-Violente (CNV) en Couple — Guides et Méthodes"
  description="Découvrez comment la Communication Non-Violente (CNV) peut transformer votre relation de couple. Guides pratiques, méthodes et exercices concrets."
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <header class="mb-10">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">Communication Non-Violente (CNV) en Couple</h1>
      <p class="text-gray-600 text-lg">Guides pratiques et méthodes pour mieux s'exprimer et s'écouter dans votre relation.</p>
    </header>

    <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {displayPosts.map(post => (
        <li>
          <ArticleCard
            title={post.data.title}
            slug={post.slug}
            pubDate={post.data.pubDate}
            metaDescription={post.data.metaDescription}
            kw_primary={post.data.kw_primary}
            tags={post.data.tags}
            image={post.data.image}
          />
        </li>
      ))}
    </ul>

    <div class="mt-12 text-center">
      <a href="/blog" class="inline-block px-6 py-3 bg-[var(--color-primary)] text-white font-semibold rounded-xl hover:opacity-90 transition-opacity">
        Voir tous les articles →
      </a>
    </div>
  </div>
</BaseLayout>
