---
import BaseLayout from "../layouts/BaseLayout.astro";
import PriceTag from "../components/PriceTag.astro";
import TrustSignals from "../components/TrustSignals.astro";
import { site } from "../../site.config.ts";

if (!site.monetization.pdf) {
  return Astro.redirect("/", 302);
}

let pdfData: {
  title: string;
  subtitle?: string;
  promise?: string;
  cover_image?: string;
  price: number;
  original_price?: number;
  pain_point: string;
  solution: string;
  features: string[];
  testimonials: Array<{ author: string; text: string }>;
  faq: Array<{ q: string; a: string }>;
  stripe_url: string;
  trust_signals?: Array<{ icon: string; text: string }>;
};

try {
  const raw = await import("/content/pdf-product.json");
  pdfData = raw.default ?? raw;
} catch {
  pdfData = {
    title: site.name,
    price: 27,
    pain_point: "Le problème que vous rencontrez.",
    solution: "La solution que nous proposons.",
    features: ["Fonctionnalité 1", "Fonctionnalité 2", "Fonctionnalité 3"],
    testimonials: [],
    faq: [],
    stripe_url: "#",
    trust_signals: [],
  };
}

const l = site.lang;

const labels: Record<string, Record<string, string>> = {
  problemTitle: { fr: "Le problème", en: "The problem", de: "Das Problem", es: "El problema" },
  solutionTitle: { fr: "La solution", en: "The solution", de: "Die Lösung", es: "La solución" },
  featuresTitle: { fr: "Ce que vous obtenez", en: "What you get", de: "Was Sie erhalten", es: "Lo que obtiene" },
  testimonialsTitle: { fr: "Ils nous font confiance", en: "They trust us", de: "Sie vertrauen uns", es: "Ellos confían en nosotros" },
  faqTitle: { fr: "Questions fréquentes", en: "FAQ", de: "Häufige Fragen", es: "FAQ" },
  ctaLabel: { fr: "Obtenir le guide maintenant", en: "Get the guide now", de: "Leitfaden jetzt holen", es: "Obtener la guía ahora" },
  guarantee: {
    fr: "Paiement sécurisé — Satisfait ou remboursé",
    en: "Secure payment — Money-back guarantee",
    de: "Sichere Zahlung — Geld-zurück-Garantie",
    es: "Pago seguro — Garantía de reembolso",
  },
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: pdfData.title,
  description: pdfData.pain_point,
  url: new URL("/pdf", site.domain || "https://parler-couple.vercel.app").href,
  offers: {
    "@type": "Offer",
    price: pdfData.price.toFixed(2),
    priceCurrency: "EUR",
    availability: "https://schema.org/InStock",
    url: pdfData.stripe_url,
  },
};

const faqSchema = pdfData.faq?.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: pdfData.faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    }
  : null;
---

<BaseLayout title={pdfData.title} description={pdfData.pain_point} canonical="/pdf">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} slot="head" />
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  )}

  <div class="max-w-3xl mx-auto px-4 py-12 space-y-14">
    <header class="text-center space-y-5">
      {pdfData.cover_image && (
        <img src={pdfData.cover_image} alt={pdfData.title} class="mx-auto max-w-xs rounded-2xl shadow-xl" />
      )}
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 leading-tight">
        {pdfData.title}
      </h1>
      {pdfData.subtitle && <p class="text-xl text-gray-600 font-medium">{pdfData.subtitle}</p>}
      {pdfData.promise && (
        <p class="text-base text-[var(--color-primary)] font-semibold bg-purple-50 border border-purple-100 rounded-xl px-6 py-3 inline-block">
          ✓ {pdfData.promise}
        </p>
      )}
      <PriceTag price={pdfData.price} originalPrice={pdfData.original_price} size="lg" />
      <a
        href={pdfData.stripe_url}
        class="inline-block mt-2 px-8 py-4 bg-[var(--color-primary)] text-white text-lg font-bold rounded-2xl hover:opacity-90 transition-opacity shadow-lg"
      >
        {labels.ctaLabel[l]}
      </a>
      <p class="text-sm text-gray-500">{labels.guarantee[l]}</p>
    </header>

    <section class="rounded-2xl bg-red-50 border border-red-100 p-8">
      <h2 class="text-xl font-bold text-red-800 mb-3">{labels.problemTitle[l]}</h2>
      <p class="text-red-700 leading-relaxed">{pdfData.pain_point}</p>
    </section>

    <section class="rounded-2xl bg-green-50 border border-green-100 p-8">
      <h2 class="text-xl font-bold text-green-800 mb-3">{labels.solutionTitle[l]}</h2>
      <p class="text-green-700 leading-relaxed">{pdfData.solution}</p>
    </section>

    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-6">{labels.featuresTitle[l]}</h2>
      <ul class="space-y-3">
        {pdfData.features.map((feature) => (
          <li class="flex items-start gap-3 p-4 rounded-xl bg-gray-50 border border-gray-100">
            <svg class="w-5 h-5 mt-0.5 text-[var(--color-primary)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-800">{feature}</span>
          </li>
        ))}
      </ul>
    </section>

    {pdfData.trust_signals && pdfData.trust_signals.length > 0 && (
      <section>
        <TrustSignals signals={pdfData.trust_signals} layout="grid" />
      </section>
    )}

    {pdfData.testimonials?.length > 0 && (
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-6">{labels.testimonialsTitle[l]}</h2>
        <ul class="space-y-4">
          {pdfData.testimonials.map((t) => (
            <li class="p-6 rounded-xl bg-white border border-gray-100 shadow-sm">
              <p class="text-gray-700 italic mb-3">"{t.text}"</p>
              <p class="text-sm font-semibold text-gray-900">— {t.author}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    <div class="text-center space-y-4 py-6">
      <PriceTag price={pdfData.price} originalPrice={pdfData.original_price} size="lg" />
      <a
        href={pdfData.stripe_url}
        class="inline-block px-8 py-4 bg-[var(--color-primary)] text-white text-lg font-bold rounded-2xl hover:opacity-90 transition-opacity shadow-lg"
      >
        {labels.ctaLabel[l]}
      </a>
      <p class="text-sm text-gray-500">{labels.guarantee[l]}</p>
    </div>

    {pdfData.faq?.length > 0 && (
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-6">{labels.faqTitle[l]}</h2>
        <dl class="space-y-4">
          {pdfData.faq.map((item) => (
            <div class="rounded-xl border border-gray-100 p-5">
              <dt class="font-semibold text-gray-800 mb-2">{item.q}</dt>
              <dd class="text-sm text-gray-600 leading-relaxed">{item.a}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}
  </div>
</BaseLayout>
